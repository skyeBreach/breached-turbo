{
    "version": "0.2",
    "language": "en-GB",
    "dictionaries": [
        "node",
        "typescript",
        "companies",
        "softwareTerms",
        "misc",
        "npm",
        "git"
    ],
    "ignorePaths": [
        "cspell.json",
        "node_modules",
        "**/*.svg",
        ".build",
        "dist",
        "tsconfig.tsbuildinfo",
        "**-lock.yaml"
    ],
    "words": [
        "Allowfunctional",
        "callsign",
        "cjsx",
        "commitlint",
        "ctsx",
        "decap",
        "Decap",
        "encorporating",
        "formik",
        "gitea",
        "IJWT",
        "mjsx",
        "mtsx",
        "nextjs",
        "pkce",
        "tailwindcss",
        "tiktok",
        "Tiktok",
        "tsbuildinfo",
        "TSES",
        "Turborepo",
        "typecheck"
    ],
    "languageSettings": [
        // Ignore commit-msg comments
        { "languageId": "commit-msg", "ignoreRegExpList": ["/^#.*/gm"] }
    ],
    "flagWords": ["hte"]
}
